{
  "manifest_version": 2,
  "name": "Ash Ocean Drift – A Firefox Theme",
  "version": "1.0",
  "author": "The Sikh Artist",
  "theme": {
    "images": {
      "theme_frame": "images/bg.png",
      "additional_backgrounds": [
        "images/waves.png"
      ]
    },
    "colors": {
      "frame": "#0ea5e9",
      "toolbar": "#0284c7",
      "toolbar_text": "#e0f2fe",
      "tab_background_text": "#ffffff"
    },
    "properties": {
      "additional_backgrounds_alignment": ["top"],
      "additional_backgrounds_tiling": ["repeat-x"]
    }
  }
}