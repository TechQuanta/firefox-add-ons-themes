{
  "manifest_version": 2,
  "name": "Ash Glassflow – A Firefox Theme",
  "version": "1.0",
  "author": "The Sikh Artist",
  "theme": {
    "images": {
      "theme_frame": "images/bg.png",
      "additional_backgrounds": [
        "images/blur.png",
        "images/light.png"
      ]
    },
    "colors": {
      "frame": "#1e293b",
      "toolbar": "#334155",
      "toolbar_text": "#f1f5f9",
      "tab_background_text": "#ffffff"
    },
    "properties": {
      "additional_backgrounds_alignment": ["top", "top"],
      "additional_backgrounds_tiling": ["no-repeat", "no-repeat"]
    }
  }
}