{
  "manifest_version": 2,
  "name": "Ash Ember Core – A Firefox Theme",
  "version": "1.0",
  "author": "The Sikh Artist",
  "theme": {
    "images": {
      "theme_frame": "images/bg.png",
      "additional_backgrounds": [
        "images/fire.png",
        "images/glow.png"
      ]
    },
    "colors": {
      "frame": "#7c2d12",
      "toolbar": "#451a03",
      "toolbar_text": "#f97316",
      "tab_background_text": "#ffffff"
    },
    "properties": {
      "additional_backgrounds_alignment": ["top", "top"],
      "additional_backgrounds_tiling": ["repeat-x", "no-repeat"]
    }
  }
}