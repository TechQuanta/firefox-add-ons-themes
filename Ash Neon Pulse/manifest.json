{
  "manifest_version": 2,
  "name": "Ash Neon Pulse – A Firefox Theme",
  "version": "1.0",
  "author": "The Sikh Artist",
  "theme": {
    "images": {
      "theme_frame": "images/bg.png",
      "additional_backgrounds": [
        "images/neon-lines.png",
        "images/glow.png"
      ]
    },
    "colors": {
      "frame": "#020617",
      "toolbar": "#020617",
      "toolbar_text": "#38bdf8",
      "tab_background_text": "#ffffff"
    },
    "properties": {
      "additional_backgrounds_alignment": ["top", "center"],
      "additional_backgrounds_tiling": ["repeat-x", "no-repeat"]
    }
  }
}